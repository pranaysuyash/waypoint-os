{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_envelope.schema.json",
  "title": "SourceEnvelope",
  "description": "Runtime SourceEnvelope contract used by src/intake/packet_models.py. This supersedes the earlier v0.1 raw-intake envelope shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_id",
    "source_system",
    "actor_type",
    "received_at",
    "content",
    "content_type"
  ],
  "properties": {
    "envelope_id": {
      "type": "string",
      "description": "Unique ID for this raw intake unit."
    },
    "source_system": {
      "type": "string",
      "enum": [
        "agency_notes",
        "traveler_form",
        "email_thread",
        "chat_history",
        "structured_import"
      ],
      "description": "Runtime source bucket. More detailed upstream origin can live in metadata."
    },
    "actor_type": {
      "type": "string",
      "enum": [
        "agent",
        "traveler",
        "owner",
        "system"
      ]
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "content": {
      "description": "Raw source content. Usually freeform text or structured JSON.",
      "oneOf": [
        { "type": "string" },
        { "type": "object", "additionalProperties": true },
        { "type": "array" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "content_type": {
      "type": "string",
      "enum": [
        "freeform_text",
        "structured_json",
        "hybrid"
      ]
    },
    "attachments": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    }
  }
}
