{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_envelope.schema.json",
  "title": "SourceEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_id",
    "schema_version",
    "source_type",
    "received_at"
  ],
  "properties": {
    "envelope_id": {
      "type": "string",
      "description": "Unique ID for this raw intake unit."
    },
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "freeform_notes",
        "structured_form",
        "partner_api",
        "whatsapp_transcript",
        "voice_transcript",
        "crm_import",
        "manual_entry",
        "email_thread",
        "attachment_extract",
        "hybrid"
      ]
    },
    "source_system": {
      "type": ["string", "null"],
      "description": "Origin system, e.g. makemytrip, whatsapp, internal_crm."
    },
    "actor_type": {
      "type": ["string", "null"],
      "enum": [
        "traveler",
        "agency_owner",
        "agent_operator",
        "system",
        null
      ]
    },
    "actor_id": {
      "type": ["string", "null"]
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "raw_text": {
      "type": ["string", "null"]
    },
    "structured_fields": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "attachments": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachment_id",
          "attachment_type"
        ],
        "properties": {
          "attachment_id": {
            "type": "string"
          },
          "attachment_type": {
            "type": "string",
            "enum": [
              "image",
              "pdf",
              "doc",
              "audio",
              "video",
              "screenshot",
              "other"
            ]
          },
          "mime_type": {
            "type": ["string", "null"]
          },
          "uri": {
            "type": ["string", "null"]
          },
          "extracted_text": {
            "type": ["string", "null"]
          },
          "metadata": {
            "type": "object",
            "default": {},
            "additionalProperties": true
          }
        }
      }
    }
  }
}
