{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical_packet.schema.json",
  "title": "CanonicalPacket",
  "description": "Agency-OS Packet v0.3 runtime serialization contract. Source of truth: src/intake/packet_models.py CanonicalPacket.to_dict().",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "stage",
    "operating_mode",
    "decision_state",
    "facts",
    "derived_signals",
    "hypotheses",
    "lifecycle",
    "ambiguities",
    "unknowns",
    "contradictions",
    "source_envelope_ids",
    "revision_count",
    "event_cursor",
    "events"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "const": "0.3"
    },
    "stage": {
      "type": "string",
      "enum": [
        "discovery",
        "shortlist",
        "proposal",
        "booking"
      ]
    },
    "operating_mode": {
      "type": "string",
      "enum": [
        "normal_intake",
        "audit",
        "emergency",
        "follow_up",
        "cancellation",
        "post_trip",
        "coordinator_group",
        "owner_review"
      ]
    },
    "decision_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ASK_FOLLOWUP",
        "PROCEED_INTERNAL_DRAFT",
        "PROCEED_TRAVELER_SAFE",
        "BRANCH_OPTIONS",
        "STOP_NEEDS_REVIEW",
        null
      ]
    },
    "facts": {
      "$ref": "#/$defs/SlotMap"
    },
    "derived_signals": {
      "$ref": "#/$defs/SlotMap"
    },
    "hypotheses": {
      "$ref": "#/$defs/SlotMap"
    },
    "lifecycle": {
      "oneOf": [
        { "$ref": "#/$defs/LifecycleInfo" },
        { "type": "null" }
      ]
    },
    "ambiguities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Ambiguity"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/UnknownField"
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Contradiction"
      }
    },
    "source_envelope_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revision_count": {
      "type": "integer",
      "minimum": 0
    },
    "event_cursor": {
      "type": "integer",
      "minimum": 0
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Event"
      }
    }
  },
  "$defs": {
    "SlotMap": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/FieldSlot"
      }
    },
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelope_id",
        "evidence_type",
        "excerpt",
        "ref_id",
        "field_path",
        "offset",
        "confidence",
        "metadata"
      ],
      "properties": {
        "envelope_id": {
          "type": "string"
        },
        "evidence_type": {
          "type": "string",
          "enum": [
            "text_span",
            "structured_field",
            "attachment_extract",
            "derived",
            "manual_entry"
          ]
        },
        "excerpt": {
          "type": "string"
        },
        "ref_id": {
          "type": "string"
        },
        "field_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "offset": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "start": { "type": "integer" },
                "end": { "type": "integer" }
              }
            },
            { "type": "null" }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "FieldSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "authority_level",
        "extraction_mode",
        "evidence_refs",
        "derived_from",
        "updated_at",
        "notes"
      ],
      "properties": {
        "value": {},
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "authority_level": {
          "type": "string",
          "enum": [
            "manual_override",
            "explicit_user",
            "imported_structured",
            "explicit_owner",
            "derived_signal",
            "soft_hypothesis",
            "unknown"
          ]
        },
        "extraction_mode": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "derived_from": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "maturity": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "stub",
            "heuristic",
            "verified",
            null
          ]
        }
      }
    },
    "Ambiguity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_name",
        "ambiguity_type",
        "raw_value",
        "normalized_value",
        "confidence",
        "evidence_refs",
        "notes"
      ],
      "properties": {
        "field_name": { "type": "string" },
        "ambiguity_type": { "type": "string" },
        "raw_value": { "type": "string" },
        "normalized_value": { "type": [ "string", "null" ] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/EvidenceRef" }
        },
        "notes": { "type": [ "string", "null" ] }
      }
    },
    "UnknownField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_name",
        "reason",
        "attempted_at",
        "notes"
      ],
      "properties": {
        "field_name": { "type": "string" },
        "reason": {
          "type": "string",
          "enum": [
            "not_present_in_source",
            "not_extracted_yet",
            "extraction_failed",
            "intentionally_unknown"
          ]
        },
        "attempted_at": { "type": [ "string", "null" ] },
        "notes": { "type": [ "string", "null" ] }
      }
    },
    "ContradictionValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "source",
        "authority",
        "timestamp"
      ],
      "properties": {
        "value": {},
        "source": { "type": "string" },
        "authority": { "type": "string" },
        "timestamp": { "type": [ "string", "null" ] }
      }
    },
    "Contradiction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "field_name",
        "values",
        "sources",
        "detected_at",
        "state",
        "resolved_at",
        "resolution",
        "resolved_by"
      ],
      "properties": {
        "field_name": { "type": "string" },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContradictionValue"
          }
        },
        "values_legacy": {
          "type": "array"
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detected_at": { "type": "string" },
        "state": {
          "type": "string",
          "enum": [
            "detected",
            "open",
            "resolved"
          ]
        },
        "resolved_at": { "type": [ "string", "null" ] },
        "resolution": { "type": [ "string", "null" ] },
        "resolved_by": { "type": [ "string", "null" ] }
      }
    },
    "LifecycleInfo": {
      "type": "object",
      "additionalProperties": true
    },
    "Event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "timestamp",
        "details"
      ],
      "properties": {
        "event_id": { "type": "integer" },
        "event_type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
