# spine-api environment variables
# Copy to .env and fill in values

# =============================================================================
# Server configuration
# =============================================================================

# Bind address (use 0.0.0.0 for container deployments)
SPINE_API_HOST=127.0.0.1

# Port (must match what your platform exposes)
SPINE_API_PORT=8000

# Number of uvicorn workers (1 for dev, 4+ for production)
SPINE_API_WORKERS=1

# Enable dev auto-reload (set to 0 in production)
SPINE_API_RELOAD=1

# =============================================================================
# CORS — comma-separated list of allowed origins
# =============================================================================
# For local dev:
SPINE_API_CORS=http://localhost:3000,http://127.0.0.1:3000

# For production (example):
# SPINE_API_CORS=https://your-frontend.com,https://www.your-frontend.com

# =============================================================================
# Safety
# =============================================================================

# Set to 1 to enable strict leakage mode globally (raises on any traveler-bundle leakage)
# Default is 0 (leakage is logged but doesn't block responses)
TRAVELER_SAFE_STRICT=0

# =============================================================================
# Hybrid Decision Engine
# =============================================================================

# Enable hybrid decision engine (cache + rules + LLM)
# Default is 1 (enabled). Set to 0 to use rule-only engine.
USE_HYBRID_DECISION_ENGINE=1

# Primary LLM provider: gemini, openai, local
# gemini = Google Gemini API (default, cost-effective)
# openai = OpenAI API (fallback)
# local = Local HuggingFace model (no API cost, slower)
LLM_PROVIDER=gemini

# =============================================================================
# Gemini API Configuration
# =============================================================================

# Your Gemini API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
# gemini-1.5-flash = Fast, cost-effective (recommended)
# gemini-1.5-pro = Better reasoning, more expensive
GEMINI_MODEL=gemini-1.5-flash

# =============================================================================
# OpenAI API Configuration (Fallback)
# =============================================================================

# Your OpenAI API key (optional, used as fallback if Gemini fails)
OPENAI_API_KEY=

# OpenAI model to use
# gpt-4o-mini = Fast, cost-effective (recommended)
# gpt-4o = Better reasoning, more expensive
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Local LLM Configuration
# =============================================================================

# Local model path (HuggingFace)
# Downloads on first use if not found locally
LOCAL_LLM_MODEL=microsoft/phi-3-mini-4k-instruct

# Local model device: cpu, cuda, auto
LOCAL_LLM_DEVICE=auto

# Maximum local model tokens (for memory management)
LOCAL_LLM_MAX_TOKENS=512

# =============================================================================
# Cache Configuration
# =============================================================================

# Decision cache TTL in days (default: 30)
DECISION_CACHE_TTL_DAYS=30

# Minimum success rate for cached decisions (default: 0.7)
DECISION_CACHE_MIN_SUCCESS_RATE=0.7

GEMINI_API_KEY=your_gemini_api_key_here

OPENAI_API_KEY=your_openai_api_key_here

HF_HUB_TOKEN=your_huggingface_token_here