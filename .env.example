# Waypoint OS environment template
# Copy to .env and fill values for your local environment.
# Never commit real secrets.

# =============================================================================
# Critical runtime settings
# =============================================================================

# REQUIRED: API signing secret
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-secret

# IMPORTANT: Trip persistence backend.
# Use sql for canonical local behavior with seeded agency data.
# Allowed values: file, json, sql
TRIPSTORE_BACKEND=sql

# Database URL for SQL-backed runtime (example uses local Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waypoint_os

# Public checker agency binding used by SQL preflight/startup checks
PUBLIC_CHECKER_AGENCY_ID=d1e3b2b6-5509-4c27-b123-4b1e02b0bf5b

# =============================================================================
# API server
# =============================================================================

SPINE_API_HOST=127.0.0.1
SPINE_API_PORT=8000
SPINE_API_WORKERS=1
SPINE_API_RELOAD=1
SPINE_API_CORS=http://localhost:3000,http://127.0.0.1:3000

# Dev-only auth bypass toggle. Leave unset/0 in normal development.
# SPINE_API_DISABLE_AUTH=1

# Expose password reset tokens in responses (dev-only; unsafe outside local)
# EXPOSE_RESET_TOKEN=1

# =============================================================================
# Safety + orchestration behavior
# =============================================================================

# 1 = block traveler output on leakage; 0 = log leakage only
TRAVELER_SAFE_STRICT=0

# Hybrid decision engine toggle (1=enabled, 0=rules only)
USE_HYBRID_DECISION_ENGINE=1

# =============================================================================
# LLM provider configuration
# =============================================================================

# Primary provider: gemini | openai | local
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI fallback
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Local model options
LOCAL_LLM_MODEL=microsoft/phi-3-mini-4k-instruct
LOCAL_LLM_DEVICE=auto
LOCAL_LLM_MAX_TOKENS=512
HF_HUB_TOKEN=your_huggingface_token_here

# =============================================================================
# Cache tuning
# =============================================================================

DECISION_CACHE_TTL_DAYS=30
DECISION_CACHE_MIN_SUCCESS_RATE=0.7

# =============================================================================
# Document extraction
# =============================================================================

# noop (dev/test) | openai_vision (production-like)
EXTRACTION_PROVIDER=noop
OPENAI_VISION_MODEL=gpt-4o
OPENAI_VISION_TIMEOUT_SECONDS=30

# Optional OpenAI vision cost estimation knobs
# OPENAI_VISION_INPUT_COST_PER_1M=2.50
# OPENAI_VISION_OUTPUT_COST_PER_1M=10.00

# =============================================================================
# Optional observability
# =============================================================================

# Backend OTLP gRPC endpoint (example)
# SPINE_OTEL_EXPORTER_OTLP_GRPC_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=spine_api