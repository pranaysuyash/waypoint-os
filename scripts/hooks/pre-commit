#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------
# Pre-commit hook: motto_v3 workflow enforcement
#
# This hook enforces objective, verifiable checks that cannot be satisfied
# by simply setting PROJECTS_AGENT_PRECOMMIT_CONFIRM=1. The confirmation
# gate requires the agent to affirm it followed the motto_v3 workflow;
# the objective checks below verify what can be mechanically verified.
#
# Checks (in order):
#   1. Escape hatch: PROJECTS_AGENT_PRECOMMIT_DISABLE=1 skips everything
#   2. Agent gate: motto_v3.md exists, agent-start refresh, confirmation
#   3. AI co-author ban (motto §20) — scan staged file contents
#   4. Python syntax check (py_compile) on staged .py files
#   5. Python lint (ruff) on staged .py files
#   6. Python type check (mypy) on staged .py files
#   7. TypeScript check (tsc --noEmit) when .ts/.tsx staged
#   8. Test verification — targeted pytest on staged test files
#   9. Acceptance contract check — Docs/ updated when code changes staged
#
# Each tool check is SKIPPED (not failed) when the toolchain is absent.
# Only a tool that runs and reports problems blocks the commit.
#
# To bypass all checks intentionally:
#   PROJECTS_AGENT_PRECOMMIT_DISABLE=1 git commit ...
# -----------------------------------------------------------------------

# =====================================================================
# 1. ESCAPE HATCH
# =====================================================================
if [ "${PROJECTS_AGENT_PRECOMMIT_DISABLE:-0}" = "1" ]; then
  echo "pre-commit: ALL CHECKS BYPASSED via PROJECTS_AGENT_PRECOMMIT_DISABLE=1" >&2
  exit 0
fi

# =====================================================================
# 2. AGENT GATE — motto_v3.md existence, context refresh, confirmation
# =====================================================================
if [ -x /Users/pranay/Projects/agent-start ] && [ "${PWD#"/Users/pranay/Projects/"}" != "${PWD}" ]; then
  _motto_file="motto_v3.md"
  if [ ! -f "$_motto_file" ]; then
    echo "pre-commit: expected $_motto_file is missing; rerun /Users/pranay/Projects/agent-start and restore the project motto before committing." >&2
    exit 1
  fi

  echo "pre-commit: reading $_motto_file and running a full motto-based repo check (code, docs, worklogs, tests) before commit." >&2

  # Refresh agent context if stale (>6 hours)
  _cmd_timeout="${PROJECTS_AGENT_PRECOMMIT_TIMEOUT_SECS:-60}"
  _run_agent_start() {
    if command -v timeout >/dev/null 2>&1; then
      timeout "$_cmd_timeout" /Users/pranay/Projects/agent-start --skip-index --quiet >/dev/null 2>&1
    elif command -v gtimeout >/dev/null 2>&1; then
      gtimeout "$_cmd_timeout" /Users/pranay/Projects/agent-start --skip-index --quiet >/dev/null 2>&1
    else
      /Users/pranay/Projects/agent-start --skip-index --quiet >/dev/null 2>&1 &
      _agent_pid=$!
      (
        sleep "$_cmd_timeout"
        kill -TERM "$_agent_pid" >/dev/null 2>&1 || true
        sleep 1
        kill -KILL "$_agent_pid" >/dev/null 2>&1 || true
      ) &
      _killer_pid=$!
      wait "$_agent_pid" >/dev/null 2>&1
      _rc=$?
      kill "$_killer_pid" >/dev/null 2>&1 || true
      wait "$_killer_pid" >/dev/null 2>&1 || true
      return "$_rc"
    fi
  }

  _ctx=".agent/SESSION_CONTEXT.md"
  _refresh_secs="${PROJECTS_AGENT_PRECOMMIT_REFRESH_SECS:-21600}"
  _need_refresh="1"
  if [ -f "$_ctx" ]; then
    _mtime="$(stat -f %m "$_ctx" 2>/dev/null || stat -c %Y "$_ctx" 2>/dev/null || echo 0)"
    case "$_mtime" in ''|*[!0-9]*) _mtime=0 ;; esac
    _now="$(date +%s)"
    _age="$((_now - _mtime))"
    if [ "$_age" -le "$_refresh_secs" ]; then
      _need_refresh="0"
    fi
  fi
  if [ "$_need_refresh" = "1" ] && ! _run_agent_start; then
    echo "pre-commit: agent-start refresh failed; rerun /Users/pranay/Projects/agent-start --skip-index and fix the issue before committing." >&2
    exit 1
  fi
  if [ -d .agent ]; then
    git add -A .agent >/dev/null 2>&1 || true
  fi
fi

# Confirmation gate — requires agent to affirm motto_v3 workflow was followed
if [ "${PROJECTS_AGENT_PRECOMMIT_CONFIRM:-0}" != "1" ]; then
  cat >&2 <<'EOF'
pre-commit: agent confirmation required.

motto_v3 workflow verification (§0.4, §0.4.1, §0.4.2):
  1. Read motto_v3.md (full document, not just Section 20)
  2. Run the full motto-based repo check (code, docs, worklogs, tests)
  3. Inspect the diff — every file, every change
  4. Implement/fix/document the work
  5. Run the needed checks (tests, typecheck, lint)
  6. Produce an acceptance contract (§0.4) with evidence tiers
  7. Update the project log / decision records as needed

Retry with:
  PROJECTS_AGENT_PRECOMMIT_CONFIRM=1 git commit ...

To bypass this gate intentionally (use only for non-agent commits):
  PROJECTS_AGENT_PRECOMMIT_DISABLE=1 git commit ...
EOF
  exit 1
fi

# =====================================================================
# 3–9. ENFORCED OBJECTIVE CHECKS
#
# Run directly against the staged diff. Each check is skipped (not failed)
# when the toolchain is absent. Failures here abort the commit.
# =====================================================================

# Gather staged files
_staged_py="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.py$' || true)"
_staged_ts="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.(ts|tsx|js|jsx)$' || true)"
_staged_any="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)"
_staged_docs="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '^Docs/' || true)"
_staged_tests="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '(test_.*\.py|_test\.py|\.test\.(ts|tsx|js|jsx))$' || true)"
# Source files that are NOT tests, NOT docs, NOT config
_staged_src="$(printf '%s\n' "$_staged_py" | grep -v -E '(test_.*\.py|_test\.py|conftest\.py)$' || true)"

# ------------------------------------------------------------------
# 3) AI co-author ban — motto §20 (hard rule)
#
# Scan staged file CONTENTS for AI agent attribution trailers.
# Also scan filenames for known AI tool artifacts.
# ------------------------------------------------------------------
if [ -n "$_staged_any" ]; then
  _coauthor_hits="$(git diff --cached -U0 2>/dev/null | grep -iE '^\+.*Co-Authored-By:[[:space:]]*(claude|anthropic|chatgpt|openai|codex|copilot|qwen|gemini|deepseek|mistral|cursor|codebuff)' || true)"
  if [ -n "$_coauthor_hits" ]; then
    echo "" >&2
    echo "pre-commit: BLOCKED — AI co-author trailer found in staged content (motto §20)." >&2
    echo "  motto_v3 §20: 'Do not add AI-agent co-author trailers to commits.'" >&2
    echo "" >&2
    echo "  Detected:" >&2
    echo "$_coauthor_hits" | head -5 | sed 's/^/    /' >&2
    echo "" >&2
    echo "  Remove the Co-Authored-By line(s) and retry." >&2
    echo "" >&2
    exit 1
  fi
fi

# ------------------------------------------------------------------
# 4) Python syntax check (py_compile) on staged .py files
#
# Fast (~1s total) catch for syntax errors and obvious import breaks.
# This is a Tier 1 (static inspection) check per motto §0.5.
# ------------------------------------------------------------------
if [ -n "$_staged_py" ] && command -v python3 >/dev/null 2>&1; then
  _py_compile_fail="0"
  _py_compile_log=""
  while IFS= read -r _pyfile; do
    if [ -f "$_pyfile" ]; then
      if ! _out="$(python3 -m py_compile "$_pyfile" 2>&1)"; then
        _py_compile_fail="1"
        _py_compile_log="${_py_compile_log}${_pyfile}: $_out"$'\n'
      fi
    fi
  done <<< "$_staged_py"
  if [ "$_py_compile_fail" = "1" ]; then
    echo "" >&2
    echo "pre-commit: BLOCKED — Python syntax error in staged file(s)." >&2
    echo "$_py_compile_log" | sed 's/^/    /' >&2
    echo "" >&2
    echo "  Fix the syntax error and retry." >&2
    echo "" >&2
    exit 1
  fi
fi

# ------------------------------------------------------------------
# 5) Python lint (ruff) on staged .py files
#
# Probe first; skip if ruff is not runnable.
# ------------------------------------------------------------------
if [ -n "$_staged_py" ]; then
  if [ -f pyproject.toml ] && grep -qiE 'tool\.ruff|\[tool\.ruff' pyproject.toml; then
    if command -v uv >/dev/null 2>&1 && uv run ruff --version >/dev/null 2>&1; then
      if ! uv run ruff check $(printf '%s\n' "$_staged_py" | tr '\n' ' ') >/tmp/_pc_ruff.log 2>&1; then
        echo "" >&2
        echo "pre-commit: BLOCKED — ruff check FAILED on staged Python files." >&2
        cat /tmp/_pc_ruff.log >&2
        rm -f /tmp/_pc_ruff.log
        echo "" >&2
        echo "  Fix lint errors and retry (or PROJECTS_AGENT_PRECOMMIT_DISABLE=1 to override)." >&2
        echo "" >&2
        exit 1
      fi
      rm -f /tmp/_pc_ruff.log
    else
      echo "pre-commit: ruff not runnable; skipping (run 'uv sync' to enable)." >&2
    fi
  fi
fi

# ------------------------------------------------------------------
# 6) Python type check (mypy) on staged .py files
#
# Probe first; skip if mypy is not runnable.
# ------------------------------------------------------------------
if [ -n "$_staged_py" ]; then
  if [ -f pyproject.toml ] && grep -qiE 'tool\.mypy|\[tool\.mypy' pyproject.toml; then
    if command -v uv >/dev/null 2>&1 && uv run mypy --version >/dev/null 2>&1; then
      _mypy_target="src"
      [ -d "$_mypy_target" ] || _mypy_target="$(printf '%s\n' "$_staged_py" | head -1)"
      if ! uv run mypy "$_mypy_target" >/tmp/_pc_mypy.log 2>&1; then
        echo "" >&2
        echo "pre-commit: BLOCKED — mypy FAILED." >&2
        cat /tmp/_pc_mypy.log >&2
        rm -f /tmp/_pc_mypy.log
        echo "" >&2
        echo "  Fix type errors and retry (or PROJECTS_AGENT_PRECOMMIT_DISABLE=1 to override)." >&2
        echo "" >&2
        exit 1
      fi
      rm -f /tmp/_pc_mypy.log
    else
      echo "pre-commit: mypy not runnable; skipping (run 'uv sync' to enable)." >&2
    fi
  fi
fi

# ------------------------------------------------------------------
# 7) TypeScript check (tsc --noEmit) when .ts/.tsx staged
#
# Probe first; skip if tsc is not installed locally.
# ------------------------------------------------------------------
if [ -n "$_staged_ts" ] && [ -f tsconfig.json ]; then
  if command -v npx >/dev/null 2>&1 && npx --no-install tsc --version >/dev/null 2>&1; then
    if ! npx --no-install tsc --noEmit >/tmp/_pc_tsc.log 2>&1; then
      echo "" >&2
      echo "pre-commit: BLOCKED — tsc --noEmit FAILED." >&2
      cat /tmp/_pc_tsc.log >&2
      rm -f /tmp/_pc_tsc.log
      echo "" >&2
      echo "  Fix type errors and retry (or PROJECTS_AGENT_PRECOMMIT_DISABLE=1 to override)." >&2
      echo "" >&2
      exit 1
    fi
    rm -f /tmp/_pc_tsc.log
  else
    echo "pre-commit: tsc not installed locally; skipping (run 'npm i -D typescript' to enable)." >&2
  fi
fi

# ------------------------------------------------------------------
# 8) Test verification — targeted pytest on staged test files
#
# When test files are staged, run them to verify they pass.
# Uses a 120s timeout per test file to prevent hanging.
# This is a Tier 2 (targeted test passed) check per motto §0.5.
#
# When ONLY source files are staged (no test files), we run a quick
# import check to verify the modules load without errors.
# ------------------------------------------------------------------
if command -v uv >/dev/null 2>&1 && uv run python -c "import pytest" >/dev/null 2>&1; then
  # Run staged test files directly
  if [ -n "$_staged_tests" ]; then
    _test_fail="0"
    _test_timeout="${PROJECTS_AGENT_PRECOMMIT_TEST_TIMEOUT:-120}"
    while IFS= read -r _testfile; do
      if [ -f "$_testfile" ]; then
        echo "pre-commit: running $_testfile ..." >&2
        if command -v timeout >/dev/null 2>&1; then
          if ! timeout "$_test_timeout" uv run pytest "$_testfile" -x -q --tb=line 2>/tmp/_pc_test.log; then
            _test_fail="1"
            echo "  FAILED: $_testfile" >&2
            tail -5 /tmp/_pc_test.log >&2 2>/dev/null || true
          fi
        elif command -v gtimeout >/dev/null 2>&1; then
          if ! gtimeout "$_test_timeout" uv run pytest "$_testfile" -x -q --tb=line 2>/tmp/_pc_test.log; then
            _test_fail="1"
            echo "  FAILED: $_testfile" >&2
            tail -5 /tmp/_pc_test.log >&2 2>/dev/null || true
          fi
        else
          # No timeout command available; run without timeout (risk of hang)
          echo "  pre-commit: no timeout command available; pytest may hang." >&2
          if ! uv run pytest "$_testfile" -x -q --tb=line 2>/tmp/_pc_test.log; then
            _test_fail="1"
            echo "  FAILED: $_testfile" >&2
            tail -5 /tmp/_pc_test.log >&2 2>/dev/null || true
          fi
        fi
        rm -f /tmp/_pc_test.log
      fi
    done <<< "$_staged_tests"
    if [ "$_test_fail" = "1" ]; then
      echo "" >&2
      echo "pre-commit: BLOCKED — staged test(s) FAILED." >&2
      echo "  Fix the failing tests and retry." >&2
      echo "  (or PROJECTS_AGENT_PRECOMMIT_DISABLE=1 to override intentionally)" >&2
      echo "" >&2
      exit 1
    fi
  fi

  # When source files are staged without test files, run import check
  if [ -n "$_staged_src" ] && [ -z "$_staged_tests" ]; then
    _import_fail="0"
    _import_log=""
    while IFS= read -r _srcfile; do
      if [ -f "$_srcfile" ]; then
        # Convert file path to module import path
        _module="$(echo "$_srcfile" | sed 's|/|.|g; s|\.py$||')"
        # Skip __init__ files and non-importable files
        case "$_module" in *__init__|*conftest|*setup|*migrate_*|*generate_*|*seed_*|*backfill_*|*scripts.*|*notebooks.*|*_test.*|*test_*|*inspect_*) continue ;; esac
        if ! _out="$(uv run python -c "import $_module" 2>&1)"; then
          _import_fail="1"
          _import_log="${_import_log}${_srcfile} -> import $_module FAILED: $(echo "$_out" | head -1)"$'\n'
        fi
      fi
    done <<< "$_staged_src"
    if [ "$_import_fail" = "1" ]; then
      echo "" >&2
      echo "pre-commit: WARNING — import check failed for staged source file(s):" >&2
      echo "$_import_log" | sed 's/^/    /' >&2
      echo "" >&2
      echo "  These files may have broken imports. Fix before committing." >&2
      echo "  (warning only — commit will proceed)" >&2
      echo "" >&2
      # Warning only, does not block — the import path conversion is imperfect
    fi
  fi
fi

# ------------------------------------------------------------------
# 9) Acceptance contract check — motto §0.4
#
# When code files are staged (not just docs/tests/config), verify that
# a Docs/ file has also been staged or exists with recent modifications.
# This enforces motto_v3 §0.4: "A completion claim without an acceptance
# contract is not complete."
#
# This is a SOFT check (warning only) because the agent may commit code
# and docs in separate commits per motto §8 (group-by-group).
# ------------------------------------------------------------------
_has_code_changes="0"
if [ -n "$_staged_src" ] || [ -n "$_staged_tests" ] || [ -n "$_staged_ts" ]; then
  _has_code_changes="1"
fi

if [ "$_has_code_changes" = "1" ]; then
  # Check if any Docs/ files are also staged
  if [ -z "$_staged_docs" ]; then
    # Only warn for significant changes (>30 lines) — trivial fixes
    # don't need a decision record per motto §0.12.
    _code_line_count="$(git diff --cached --stat -- '*.py' '*.ts' '*.tsx' '*.js' '*.jsx' 2>/dev/null | tail -1 | grep -oE '[0-9]+ insertion' | head -1 | grep -oE '[0-9]+' || echo 0)"
    _code_line_count="${_code_line_count:-0}"
    if [ "$_code_line_count" -gt 30 ]; then
      # Check if any decision records exist in Docs/ at all
      _recent_docs=""
      if [ -d Docs/ ]; then
        _recent_docs="$(find Docs/ -name '*.md' -mtime -1 2>/dev/null | head -1 || true)"
      fi
      if [ -z "$_recent_docs" ]; then
        echo "" >&2
        echo "pre-commit: WARNING — motto §0.4 acceptance contract check." >&2
        echo "  Code files are staged but no Docs/ files are staged and no recent" >&2
        echo "  decision records found in Docs/." >&2
        echo "" >&2
        echo "  motto_v3 §0.4 requires an acceptance contract before calling work" >&2
        echo "  complete. For meaningful changes, create a decision record per §0.12:" >&2
        echo "    Docs/<TOPIC>_DECISION_RECORD_<DATE>.md" >&2
        echo "" >&2
        echo "  (warning only — commit will proceed)" >&2
        echo "" >&2
      fi
    fi
  fi
fi

# =====================================================================
# DONE — all checks passed
# =====================================================================
echo "pre-commit: all objective checks passed (motto_v3 compliance verified)." >&2
exit 0
