# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/
venv/
env/
.envrc
.python-version

# Environment variables
.env
.env.local
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Jupyter checkpoints
.ipynb_checkpoints/

# Logs
*.log

# Test/type/lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Notebook and Python caches
**/__pycache__/
**/*.pyc

# IDE and tool state
.agent/
.qwen/
.kiro/
.claude/worktrees/
.claude/settings.local.json
.vscode/
.idea/
.deepseek/
*.swp
*.swo
*~

# Package manager locks (project uses uv; lockfile is source-controlled
# but local lock diffs are noise)
# uv.lock is tracked intentionally

# Frontend generated files
node_modules/
frontend/node_modules/
frontend/.next/

# Playwright MCP
.playwright-mcp/

# Data files — downloaded datasets (186MB total)
data/cities5000.txt
data/cities.json

# Data files — generated/accumulated at runtime
data/accumulated_cities.json
data/accumulated_cities.lock

# Ignore node-generated lockfiles (we use uv)
package-lock.json
package.json

# Ignore dogfood cookies
dogfood_cookies.txt

# Data files — runtime caches (decision engine outputs, audit logs)
data/decision_cache/
data/audit/
!data/decision_cache/.gitkeep
!data/audit/.gitkeep

# Data files — overrides (runtime-created, not source)
data/overrides/
# Document storage runtime files
data/documents/
# Data files — generated trip seed data (runtime-created per test/seed run)
data/trips/trip_seed_*.json

# Data files — generated runtime trips and runs
# Keep fixture-style files tracked separately if needed; ignore runtime trip artifacts.
data/trips/trip_*.json
data/runs/
data/logs/trips

# Data files — shadow mode runtime outputs
data/shadow/outputs/

# Local scratch workspace
scratch/

# Design reference files (HTML assets)
Archive/design_refs/

# Browser/QA tool state
.gstack/

# Responsive audit output
Docs/responsive-audit/

# Database files (SQLite/JSON stores created at runtime)
*.db
*.sqlite
*.sqlite3
# Trip processing lock files (should not be tracked)
data/trips/*.lock
